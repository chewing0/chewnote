OPENAI_API_KEY=your_api_key
OPENAI_BASE_URL=https://api.moonshot.cn/v1
OPENAI_MODEL=moonshot-v1-8k
APP_TIMEZONE=Asia/Shanghai
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/chewnote_agent
