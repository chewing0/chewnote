AUTH_SECRET_KEY=change-this-long-random-secret
AUTH_ACCESS_TOKEN_MINUTES=30
AUTH_REFRESH_TOKEN_DAYS=30
AUTH_PASSWORD_RESET_MINUTES=30
AUTH_DEV_RETURN_RESET_TOKEN=true
AGENT_DEBUG_ERRORS=false
SMTP_HOST=
